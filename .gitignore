# Nested git backups (local only; do not commit)
.nested-git-backup/

# OS
.DS_Store

# Rust (softprobe-proxy)
softprobe-proxy/target/
softprobe-proxy/**/*.rs.bk

# Java (softprobe-java)
softprobe-java/target/

# Python (softprobe-python)
softprobe-python/**/__pycache__/
softprobe-python/**/*.pyc

# Python (e2e pytest harness)
e2e/pytest-replay/**/__pycache__/
e2e/pytest-replay/**/*.pyc

# Node (softprobe-js)
softprobe-js/node_modules/
softprobe-js/dist/
softprobe-js/coverage/
softprobe-js/.nyc_output/
softprobe-js/*.tsbuildinfo

# Env and secrets
.env
.env.*
!.env.example
.gcp-*.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# E2E capture output (regenerated by capture/replay tests)
e2e/captured.case.json
e2e/envoy.cloud.yaml

# Node (e2e jest harnesses)
e2e/jest-replay/node_modules/
e2e/jest-hooks/node_modules/

# Java (e2e junit harness)
e2e/junit-replay/target/

# CLI suite-run harness artifacts
e2e/cli-suite-run/out/

# Go (softprobe-runtime local build outputs)
softprobe-runtime/softprobe
softprobe-runtime/softprobe-runtime

# Top-level CLI binary produced by `go build -o ../softprobe`
/softprobe

# Local `go build` artifact in softprobe-cli workspace
softprobe-cli/softprobe

# Cross-compiled CLI binaries (produced by softprobe-cli-release workflow)
/dist/
