{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "types": ["jest", "node"],
    "paths": {
      "@softprobe/softprobe-js": ["src/index.ts"],
      "@softprobe/softprobe-js/hooks": ["src/hooks.ts"],
      "@softprobe/softprobe-js/suite": ["src/suite.ts"]
    }
  },
  "include": ["src/**/*", "examples/**/*"],
  "exclude": ["node_modules", "dist"]
}
