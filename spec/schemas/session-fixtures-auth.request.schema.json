{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://softprobe.dev/spec/session-fixtures-auth.request.schema.json",
  "title": "Softprobe Session Auth Fixtures Request",
  "type": "object",
  "properties": {
    "tokens": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cookies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": "string" },
          "domain": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    }
  },
  "additionalProperties": false
}
