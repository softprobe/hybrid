{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://softprobe.dev/spec/session-create.request.schema.json",
  "title": "Softprobe Session Create Request",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": { "type": "string", "enum": ["capture", "replay", "generate"] },
    "policy": {
      "type": "object",
      "properties": {
        "externalHttp": { "type": "string", "enum": ["strict", "allow"] },
        "defaultOnMiss": { "type": "string", "enum": ["error", "passthrough"] },
        "allowHosts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockHosts": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
