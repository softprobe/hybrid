{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://softprobe.dev/spec/rule.schema.json",
  "title": "Softprobe Rule",
  "type": "object",
  "required": ["when", "then"],
  "properties": {
    "id": { "type": "string" },
    "priority": { "type": "integer" },
    "consume": { "type": "string", "enum": ["once", "many"] },
    "when": { "type": "object" },
    "then": { "type": "object" }
  },
  "additionalProperties": true
}
